# ════════════════════════════════════════════
# Sber STT (SaluteSpeech gRPC)
# Required: full Sber RCE key (or via SBER_CLIENT_ID + SBER_CLIENT_SECRET)
SBER_VOICE_API_KEY=your_rce_key_here
# Or via separate components (alternative to SBER_VOICE_API_KEY):
# SBER_CLIENT_ID=your_client_id
# SBER_CLIENT_SECRET=your_client_secret
# Optional
SBER_SCOPE=SALUTE_SPEECH_PERS

# TTS Service (Silero microservice)
# Agents use the TTS microservice (HTTP). torch/Silero run only there.
TTS_SERVICE_URL=http://127.0.0.1:8090

# ════════════════════════════════════════════
# LiveKit Agent — agent-container
# Required
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LLM_BASE_URL=http://localhost:11434/v1
# Optional
LLM_API_KEY=
LLM_MODEL=llama3.1:8b

# ════════════════════════════════════════════
# SIP / Mango
# ════════════════════════════════════════════
EXTERNAL_IP=your_public_ip
MANGO_LOGIN=gpt_assistant
MANGO_PASSWORD=your_mango_password
SIP_OUTBOUND_TRUNK_ID=your_outbound_trunk_id

# Common
# ════════════════════════════════════════════
LOG_LEVEL=INFO
